{
  "name": "duka-pos",
  "version": "0.1.0",
  "description": "Lightweight POS for small retail shops and dukas in Kenya",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --win",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Duka POS",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "axios": "^1.7.0",
    "node-thermal-printer": "^4.4.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "vitest": "^1.0.0"
  },
  "build": {
    "appId": "com.dukapos.app",
    "productName": "Duka POS",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      "src/db/schema.sql"
    ]
  }
}
